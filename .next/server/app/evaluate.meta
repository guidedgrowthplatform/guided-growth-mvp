{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/evaluate/layout,_N_T_/evaluate/page,_N_T_/evaluate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/evaluate/__PAGE__",
    "/evaluate",
    "/_index",
    "/_head"
  ]
}