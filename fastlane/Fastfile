default_platform(:ios)

# ---------------------------------------------------------------------------
# iOS — build IPA and upload to TestFlight
# ---------------------------------------------------------------------------
platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Per-environment bundle id (dev / staging / main); defaults to production.
    app_id = ENV.fetch("APP_IDENTIFIER", "app.guidedgrowth.mvp")
    match_branch = ENV.fetch("MATCH_GIT_BRANCH", "main")

    # --- App Store Connect API key (preferred over Apple ID in CI) ----------
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),   # .p8 contents (base64 in CI)
      is_key_content_base64: true,
      in_house: false
    )

    # --- Code signing -------------------------------------------------------
    setup_ci if ENV["CI"]

    # Fastlane match pulls certs + profiles from a private git repo.
    # Set MATCH_GIT_URL, MATCH_PASSWORD in CI variables.
    # `clone_branch_directly` skips full git clone (avoids minutes-long hangs
    # on CI when the match repo is large or slow to fetch).
    match(
      type: "appstore",
      app_identifier: app_id,
      readonly: true,
      git_branch: match_branch,
      clone_branch_directly: true,
      api_key: api_key
    )

    # --- Increment build number to current pipeline ID ---------------------
    increment_build_number(
      build_number: ENV["CI_PIPELINE_IID"] || ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "ios/App/App.xcodeproj"
    )

    # --- Marketing version: explicit APP_VERSION, else the vX.Y.Z tag -------
    # APP_VERSION covers tagless dispatch builds (else stuck at 1.0.0).
    version_source = ENV["APP_VERSION"] || ENV["CI_COMMIT_TAG"] || ENV["GITHUB_REF_NAME"]
    if version_source && version_source =~ /^v?(\d+\.\d+\.\d+)/
      increment_version_number(
        version_number: $1,
        xcodeproj: "ios/App/App.xcodeproj"
      )
    end

    # --- Pin manual code signing -------------------------------------------
    # `cap add ios` generates a project with automatic signing enabled,
    # which makes xcodebuild look for an Apple ID account + a development
    # profile in CI — neither exists. Switch to manual signing and point
    # at the exact AppStore profile match just installed. The profile
    # name comes back from match in lane_context.
    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][app_id]

    update_code_signing_settings(
      path: "ios/App/App.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      bundle_identifier: app_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"]
    )

    # --- Build --------------------------------------------------------------
    # Capacitor 8 uses Swift Package Manager, which generates only an
    # .xcodeproj (no top-level .xcworkspace). Earlier CocoaPods-based
    # Capacitor versions produced a workspace — kept here for posterity.
    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build/ios",
      output_name: "GuidedGrowth.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )

    # --- Upload to TestFlight -----------------------------------------------
    # Shared tester notes; same file feeds Play release notes in ci.yml.
    # __dir__-anchored so cwd doesn't matter.
    notes_path = File.expand_path("../release-notes/whatsnew-en-US", __dir__)
    changelog = File.exist?(notes_path) ? File.read(notes_path).strip : nil

    # Wait for processing so changelog ("What to Test") reliably attaches;
    # bounded timeout fails loud instead of hanging on a slow Apple queue.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      wait_processing_timeout_duration: 1800,
      changelog: changelog
    )
  end

  desc "ONE-TIME bootstrap: populate match repo with distribution cert + appstore profile"
  # Run via the match-bootstrap workflow (manual dispatch only). Requires
  # the deploy key on the match-certificates GitLab repo to have WRITE
  # permission for the duration of the run. Revoke write permission
  # afterwards.
  lane :bootstrap_match do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )

    setup_ci if ENV["CI"]

    match(
      type: "appstore",
      app_identifier: ENV.fetch("APP_IDENTIFIER", "app.guidedgrowth.mvp"),
      readonly: false,
      git_branch: ENV.fetch("MATCH_GIT_BRANCH", "main"),
      api_key: api_key
    )
  end
end

# ---------------------------------------------------------------------------
# Android — build signed release APK + AAB
# ---------------------------------------------------------------------------
platform :android do
  desc "Build signed release APK"
  lane :build do
    # --- Build release APK using Gradle -------------------------------------
    # Signing is injected via Gradle properties from CI variables.
    gradle(
      project_dir: "android",
      task: "assemble",
      build_type: "Release",
      properties: {
        "android.injected.signing.store.file"     => ENV.fetch("ANDROID_KEYSTORE_PATH", ""),
        "android.injected.signing.store.password"  => ENV.fetch("ANDROID_KEYSTORE_PASSWORD", ""),
        "android.injected.signing.key.alias"       => ENV.fetch("ANDROID_KEY_ALIAS", ""),
        "android.injected.signing.key.password"    => ENV.fetch("ANDROID_KEY_PASSWORD", "")
      }
    )

    # Copy APK to a known location for CI artifact collection
    sh("mkdir -p ../build/android")
    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]
    sh("cp '#{apk_path}' ../build/android/GuidedGrowth-release.apk") if apk_path
  end

  desc "Build signed release AAB (for Play Store)"
  lane :bundle do
    gradle(
      project_dir: "android",
      task: "bundle",
      build_type: "Release",
      properties: {
        "android.injected.signing.store.file"     => ENV.fetch("ANDROID_KEYSTORE_PATH", ""),
        "android.injected.signing.store.password"  => ENV.fetch("ANDROID_KEYSTORE_PASSWORD", ""),
        "android.injected.signing.key.alias"       => ENV.fetch("ANDROID_KEY_ALIAS", ""),
        "android.injected.signing.key.password"    => ENV.fetch("ANDROID_KEY_PASSWORD", "")
      }
    )

    sh("mkdir -p ../build/android")
    aab_path = lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]
    sh("cp '#{aab_path}' ../build/android/GuidedGrowth-release.aab") if aab_path
  end
end
