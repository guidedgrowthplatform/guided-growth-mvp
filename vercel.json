{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "functions": {
    "api/**/*": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), geolocation=(), microphone=(self)"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.vapi.ai wss://api.vapi.ai https://*.daily.co wss://*.daily.co https://*.ingest.us.sentry.io https://*.ingest.de.sentry.io https://*.ingest.sentry.io https://*.sentry.io wss://stt-rt.soniox.com https://stt-rt.soniox.com https://api.cartesia.ai wss://api.cartesia.ai"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "crons": [{ "path": "/api/notifications/cron", "schedule": "0 * * * *" }],
  "rewrites": [
    { "source": "/api/onboarding", "destination": "/api/onboarding/__index" },
    { "source": "/api/notifications", "destination": "/api/notifications/__index" },
    { "source": "/api/reflections", "destination": "/api/reflections/__index" },
    { "source": "/api/admin", "destination": "/api/admin/__index" },
    { "source": "/api/session_log", "destination": "/api/session_log/__index" },
    { "source": "/api/context", "destination": "/api/context/__index" },
    { "source": "/api/llm", "destination": "/api/llm/__index" },
    { "source": "/api/calendar", "destination": "/api/calendar/__index" },
    {
      "source": "/ingest/static/(.*)",
      "destination": "https://us-assets.i.posthog.com/static/$1"
    },
    { "source": "/ingest/decide", "destination": "https://us.i.posthog.com/decide" },
    { "source": "/ingest/(.*)", "destination": "https://us.i.posthog.com/$1" },
    { "source": "/((?!api/|ingest/).*)", "destination": "/index.html" }
  ]
}
