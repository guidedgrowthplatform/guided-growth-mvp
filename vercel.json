{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "functions": {
    "api/**/*": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), geolocation=(), microphone=(self)"
        },
        {
          "key": "X-Content-Security-Policy",
          "value": "frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "rewrites": [
    { "source": "/api/onboarding", "destination": "/api/onboarding/__index" },
    { "source": "/api/metrics", "destination": "/api/metrics/__index" },
    { "source": "/api/entries", "destination": "/api/entries/__index" },
    { "source": "/api/reflections", "destination": "/api/reflections/__index" },
    { "source": "/api/admin", "destination": "/api/admin/__index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
