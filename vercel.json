{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=(), microphone=(self)" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/metrics", "destination": "/api/metrics/__index" },
    { "source": "/api/entries", "destination": "/api/entries/__index" },
    { "source": "/api/reflections", "destination": "/api/reflections/__index" },
    { "source": "/api/admin", "destination": "/api/admin/__index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
