    53	  if (value && typeof value === 'object') {
    54	    return Object.fromEntries(
    55	      Object.keys(value)
    56	        .sort()
    57	        .map((key) => [key, canonical(value[key])]),
    58	    );
    59	  }
    60	  return value;
    61	}
    62	
    63	function projection(beat) {
    64	  return {
    65	    ...Object.fromEntries(COPY_FIELDS.map((field) => [field, beat[field]])),
    66	    script: beat.script.map((line) => ({
    67	      seq: line.seq,
    68	      words: line.words,
    69	      bindsTo: line.bindsTo,
    70	      voice: line.voice,
    71	      clip: line.clip,
    72	      clipPath: line.clipPath,
    73	      expectedUser: line.expectedUser,
    74	    })),
    75	  };
    76	}
    77	
    78	function gitShow(revision, file) {
    79	  return execFileSync('git', ['show', `${revision}:${file}`], { cwd: ROOT, encoding: 'utf8' });
    80	}
    81	
    82	function hasGitRepository() {
    83	  return existsSync(path.join(ROOT, '.git'));
    84	}
    85	
    86	function loadBaseline() {
    87	  const snapshot = path.join(ROOT, BASELINE_PATH);
    88	  if (existsSync(snapshot)) return JSON.parse(readFileSync(snapshot, 'utf8'));
    89	  if (!hasGitRepository()) {
    90	    fail(`baseline: missing ${BASELINE_PATH}; no .git checkout is available for fallback`);
    91	  }
    92	  return loadModule(gitShow(NEW_SHA, BEATS_PATH), 'baseline.ts').BEATS_SOURCE.map(projection);
    93	}
    94	
    95	function checkTypesOnly() {
    96	  const file = path.join(ROOT, FLOW_BIBLE_PATH);
    97	  const source = readFileSync(file, 'utf8');
    98	  const ast = ts.createSourceFile(file, source, ts.ScriptTarget.Latest, true);
    99	  for (const statement of ast.statements) {
   100	    if (!ts.isInterfaceDeclaration(statement) && !ts.isTypeAliasDeclaration(statement)) {
   101	      fail(`types-only: forbidden ${ts.SyntaxKind[statement.kind]} in ${FLOW_BIBLE_PATH}`);
   102	    }
   103	  }
   104	}
   105	
   106	function diffValues(oldValue, newValue, fieldPath, deltas) {
   107	  if (JSON.stringify(canonical(oldValue)) === JSON.stringify(canonical(newValue))) return;
   108	  if (Array.isArray(oldValue) && Array.isArray(newValue)) {
   109	    const count = Math.max(oldValue.length, newValue.length);
   110	    for (let index = 0; index < count; index += 1) {
   111	      diffValues(oldValue[index], newValue[index], `${fieldPath}[${index}]`, deltas);
   112	    }
   113	    return;
   114	  }
   115	  if (oldValue && newValue && typeof oldValue === 'object' && typeof newValue === 'object') {
   116	    const keys = new Set([...Object.keys(oldValue), ...Object.keys(newValue)]);
   117	    for (const key of [...keys].sort()) diffValues(oldValue[key], newValue[key], `${fieldPath}.${key}`, deltas);
   118	    return;
   119	  }
   120	  deltas.push({ path: fieldPath, old: oldValue, new: newValue });
   121	}
   122	
   123	function lockedCopyDeltas(baseline, target) {
   124	  const targetById = new Map(target.map((beat) => [beat.id, projection(beat)]));
   125	  const deltas = [];
   126	  for (const oldBeat of baseline) {
   127	    const newBeat = targetById.get(oldBeat.id);
   128	    if (!newBeat) {
   129	      deltas.push({ path: `${oldBeat.id}`, old: 'present', new: 'missing' });
   130	      continue;
   131	    }
   132	    diffValues(oldBeat, newBeat, oldBeat.id, deltas);
   133	  }
   134	  return deltas;
   135	}
   136	
   137	function assertExpectedDeltas(deltas) {
   138	  for (const delta of deltas) {
   139	    console.log(`locked-copy delta: ${delta.path}\n  old: ${JSON.stringify(delta.old)}\n  new: ${JSON.stringify(delta.new)}`);
   140	  }
   141	  if (JSON.stringify(deltas) !== JSON.stringify(SANCTIONED_DELTAS)) {
   142	    fail(
   143	      `locked copy: expected exactly ${JSON.stringify(SANCTIONED_DELTAS, null, 2)}, got ${JSON.stringify(deltas, null, 2)}`,
   144	    );
   145	  }
   146	}
   147	
   148	function trackedSourceFiles(directory) {
   149	  const ignored = new Set(['.git', 'node_modules', 'dist', 'dist-flow', 'coverage']);
   150	  const files = [];
   151	  for (const entry of readdirSync(directory)) {
   152	    if (ignored.has(entry)) continue;
   153	    const fullPath = path.join(directory, entry);
   154	    const stats = statSync(fullPath);
   155	    if (stats.isDirectory()) files.push(...trackedSourceFiles(fullPath));
   156	    else if (/\.(?:[cm]?[jt]sx?)$/.test(entry)) files.push(fullPath);
   157	  }
   158	  return files;
   159	}
   160	
   161	function checkNoLegacyConsumer() {
   162	  const offenders = trackedSourceFiles(ROOT).filter((file) => {
   163	    const source = readFileSync(file, 'utf8');
   164	    return /(?:from|import)\s+.*["'][^"']*beatMetadata/.test(source);
   165	  });
   166	  if (offenders.length) fail(`consumer: tracked beatMetadata import remains in ${offenders.join(', ')}`);
   167	}
   168	
   169	function main() {
   170	  checkTypesOnly();
   171	  const baseline = loadBaseline();
   172	  const target = loadModule(readFileSync(path.join(ROOT, BEATS_PATH), 'utf8'), 'target.ts').BEATS_SOURCE;
   173	  const map = JSON.parse(readFileSync(path.join(ROOT, MAP_PATH), 'utf8'));
   174	  if (baseline.length !== 62 || target.length !== 62) {
   175	    fail(`structure: expected 62 beats, got baseline=${baseline.length}, target=${target.length}`);
   176	  }
   177	  if (new Set(target.map((beat) => beat.id)).size !== 62) fail('structure: target IDs are not unique');
   178	  const baselineIds = baseline.map((beat) => beat.id);
   179	  const targetIds = target.map((beat) => beat.id);
   180	  if (JSON.stringify(baselineIds) !== JSON.stringify(targetIds)) fail('structure: target ID sequence differs from baseline');
   181	  assertExpectedDeltas(lockedCopyDeltas(baseline, target));
   182	
   183	  const targetById = new Map(target.map((beat) => [beat.id, beat]));
   184	  for (const beat of target) {
   185	    if (!beat.bible || !beat.io) fail(`rich data: ${beat.id} is missing bible or io`);
   186	    if (!['MP3', 'Cartesia', 'Vapi', 'Silent'].includes(beat.voiceEngine)) fail(`matrix: ${beat.id}.voiceEngine`);
   187	    if (beat.voiceEngine !== 'Silent' && beat.voiceMode === 'Verbatim' && !beat.spokenContent && !beat.script.length) {
   188	      fail(`matrix: ${beat.id} has no spoken content`);
   189	    }
   190	    if (beat.id.includes(':') && !beat.parent) fail(`parent: ${beat.id} has no display parent`);
   191	  }
   192	  for (const row of map) {
   193	    if (!targetById.has(row.targetId)) fail(`Rename Map: missing target ${row.targetId}`);
   194	  }
   195	
   196	  for (const oldId of ['state-check', 'checkin', 'reflection', 'goal-custom', 'habit-custom', 'schedule', 'advanced-capture', 'advanced-frequency', 'plan']) {
   197	    const targetId = map.find((row) => row.oldId === oldId)?.targetId;
   198	    const io = targetById.get(targetId)?.io;
   199	    if (!io || !Array.isArray(io.dataIn) || !Array.isArray(io.dataOut)) fail(`coverage persistence: ${oldId}`);
   200	  }
   201	  for (const oldId of ['checkin', 'goal-custom', 'habit-custom']) {
   202	    const targetId = map.find((row) => row.oldId === oldId)?.targetId;
   203	    if (!targetById.get(targetId)?.bible?.allowedTools) fail(`coverage tools: ${oldId}`);
   204	  }
   205	  for (const oldId of ['weekly-blank', 'weekly-full', 'weekly-p78', 'weekly-p36', 'weekly-gaps']) {
   206	    const targetId = map.find((row) => row.oldId === oldId)?.targetId;
   207	    if (!targetById.get(targetId)?.bible?.components) fail(`coverage components: ${oldId}`);
   208	  }
   209	  checkNoLegacyConsumer();
   210	  console.log('Objective 1 verified: 62 beats, exactly 2 locked-copy deltas, rich contracts and coverage complete.');
   211	}
   212	
   213	main();

