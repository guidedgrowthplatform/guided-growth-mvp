    19	  {
    20	    path: 'onboarding-beat-6-profile:greeting.script[0].words',
    21	    old: 'Good to meet you, {name}. Two quick things so I can tailor this to you.',
    22	    new: 'Awesome {name}, two quick things so I can tailor this to you.',
