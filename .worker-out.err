     1	/**
     2	 * Generate src/generated/onboarding_combined.json — the single unified per-beat
     3	 * view the team asked for: engine metadata AND coach context in one JSON.
     4	 *
     5	 * This is a GENERATED merge of the two existing sources, not a new source of
     6	 * truth. Nothing the coach or frontend reads at runtime changes:
     7	 *   - engine metadata (voiceEngine, mode, mp3 clip, fill brain, toggles, engine)
     8	 *       ← the flow builder, via onboarding-beginner-v1.generated.json node.meta
     9	 *         (authored in designer-source.json, produced by npm run flow:sync)
    10	 *   - coach context + opener
    11	 *       ← beatContexts.ts (Master Sheet "Beats Context" tab, synced in)
    12	 *   - globalContext
    13	 *       ← GLOBAL_ONBOARDING_CONTEXT
    14	 *
    15	 * So this file lets anyone see everything about a beat in one place. The Sheet
    16	 * stays the source for context and the builder stays the source for metadata;
    17	 * re-run this after `npm run flow:sync` or a context sync. Making THIS file the
    18	 * single authored source (dropping the Sheet for context) is a separate, team
    19	 * decision, not done here.
    20	 *
    21	 *   npx tsx scripts/build-onboarding-combined.ts
    22	 */
    23	import { writeFileSync } from 'fs';
    24	import { resolve } from 'path';
    25	import {
    26	  BEAT_CONTEXTS,
    27	  GLOBAL_ONBOARDING_CONTEXT,
    28	  BEAT_CONTEXT_VERSION,
    29	} from '../api/_lib/llm/onboarding/beatContexts.ts';
    30	import flow from '../src/onboarding-flow/flows/onboarding-beginner-v1.generated.json';
    31	
    32	interface FlowNode {
    33	  id: string;
    34	  screenId: string;
    35	  componentType?: string;
    36	  meta?: unknown;
    37	}
    38	const nodes = flow.nodes as FlowNode[];
    39	
    40	const beats = nodes.map((n) => {
    41	  const ctx = BEAT_CONTEXTS[n.screenId as keyof typeof BEAT_CONTEXTS] as
    42	    | { context?: string; opener?: string }
    43	    | undefined;
    44	  return {
    45	    id: n.id,
    46	    screenId: n.screenId,
    47	    componentType: n.componentType ?? null,
    48	    // engine metadata (flow builder)
    49	    meta: n.meta ?? null,
    50	    // coach brain (beatContexts.ts, Sheet-synced) — null if this beat has none
    51	    coachContext: ctx?.context ?? null,
    52	    opener: ctx?.opener ?? null,
    53	  };
    54	});
    55	
    56	const out = {
    57	  _comment:
    58	    'AUTO-GENERATED unified per-beat view by scripts/build-onboarding-combined.ts. ' +
    59	    'Merges engine metadata (flow builder) + coach context/opener (beatContexts.ts, Sheet-synced) + global. ' +
    60	    'Sources of truth unchanged. Re-run after flow:sync or a context sync. Do not edit by hand.',
    61	  flowId: (flow as { id?: string }).id ?? 'onboarding-beginner-v1',
    62	  contextVersion: BEAT_CONTEXT_VERSION,
    63	  globalContext: GLOBAL_ONBOARDING_CONTEXT,
    64	  beats,
    65	};
    66	
    67	const path = resolve(import.meta.dirname, '../src/generated/onboarding_combined.json');
    68	writeFileSync(path, JSON.stringify(out, null, 2) + '\n', 'utf-8');
    69	const withCtx = beats.filter((b) => b.coachContext).length;
    70	const withMeta = beats.filter((b) => b.meta && Object.keys(b.meta as object).length > 0).length;
    71	console.log(
    72	  `Wrote src/generated/onboarding_combined.json (${beats.length} beats, ${withMeta} with engine metadata, ${withCtx} with coach context, global ${GLOBAL_ONBOARDING_CONTEXT.length} chars)`,
    73	);

