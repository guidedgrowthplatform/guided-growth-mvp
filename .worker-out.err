    99	function isExpiredPreviousResponse(err: unknown): boolean {
   100	  if (!err || typeof err !== 'object') return false;
   101	  const status = (err as { status?: number }).status;
   102	  const code = (err as { code?: string }).code;
   103	  const message = (err as { message?: string }).message ?? '';
   104	  if (status === 404 || code === 'response_not_found') return true;
   105	  if (/previous_response_id/i.test(message) && /not.*found|expired/i.test(message)) return true;
   106	  return false;
   107	}
   108	
   109	export default async function handler(req: VercelRequest, res: VercelResponse) {
   110	  if (handlePreflight(req, res)) return;
   111	
   112	  const raw = req.query['...path'];
   113	  const segments = Array.isArray(raw) ? raw : raw ? [raw] : [];
   114	  const route = segments[0] === '__index' ? '' : segments[0] || '';
   115	
   116	  // Warmup fast path: fired by the client at app-open to pre-warm this function
   117	  // + the pg pool before the user's first real LLM call. No auth, no rate
   118	  // limit, no OpenAI touch — just boots the function and pings the DB pool.
   119	  // Kept ahead of ALL other checks (including the route-404 gate) so it never
   120	  // risks getting entangled with auth/rate-limit/parsing changes below.
   121	  if (route === 'warmup' && req.method === 'GET') {
   122	    const dbStart = performance.now();
   123	    let db_ms: number;
   124	    try {
   125	      await pool.query('SELECT 1');
   126	      db_ms = Math.round(performance.now() - dbStart);
   127	    } catch {
   128	      // A failing warmup must never alarm the client — the function boot
   129	      // itself already happened, which is most of the value.
   130	      db_ms = -1;
   131	    }
   132	    return res.status(200).json({ warm: true, db_ms });
   133	  }
   134	
   135	  if (route !== '' && route !== 'parse-brain-dump' && route !== 'checkin-tool') {
   136	    return res.status(404).json({ error: 'Not found' });
   137	  }
   138	
   139	  if (req.method !== 'POST') {
   140	    return res.status(405).json({ error: 'Method not allowed' });
   141	  }
   142	
   143	  // QA visibility flag: `x-gg-debug: 1` echoes the failing stage + error class
