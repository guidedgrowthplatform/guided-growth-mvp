     1	import { mkdir, readFile, writeFile } from 'node:fs/promises';
     2	import path from 'node:path';
     3	import ts from 'typescript';
     4	
     5	const root = process.cwd();
     6	const beatsSourcePath = path.join(root, 'src/components/flow-designer/beatsSource.ts');
     7	const outputPath = path.join(root, 'dist-flow/parity.json');
     8	const headersPath = path.join(root, 'dist-flow/_headers');
     9	const headers = `/
    10	  Cache-Control: no-store
    11	/index.html
    12	  Cache-Control: no-store
    13	/parity.json
    14	  Cache-Control: no-store
    15	  Content-Type: application/json; charset=utf-8
    16	/play/*
    17	  Cache-Control: no-store
    18	/assets/*
    19	  Cache-Control: public, max-age=31536000, immutable
    20	`;
    21	
    22	function literalValue(node) {
    23	  if (ts.isStringLiteral(node) || ts.isNoSubstitutionTemplateLiteral(node)) return node.text;
    24	  if (node.kind === ts.SyntaxKind.NullKeyword) return null;
    25	  if (node.kind === ts.SyntaxKind.TrueKeyword) return true;
    26	  if (node.kind === ts.SyntaxKind.FalseKeyword) return false;
    27	  if (ts.isNumericLiteral(node)) return Number(node.text);
    28	  if (ts.isObjectLiteralExpression(node)) return objectValue(node);
    29	  if (ts.isArrayLiteralExpression(node)) return node.elements.map(literalValue);
    30	
    31	  throw new Error(`Unsupported BEATS literal: ${ts.SyntaxKind[node.kind]}`);
    32	}
    33	
    34	function propertyName(name) {
    35	  if (ts.isIdentifier(name) || ts.isStringLiteral(name) || ts.isNumericLiteral(name))
    36	    return name.text;
    37	  throw new Error(`Unsupported BEATS property name: ${ts.SyntaxKind[name.kind]}`);
    38	}
    39	
    40	function objectValue(node) {
    41	  const out = {};
    42	  for (const prop of node.properties) {
    43	    if (!ts.isPropertyAssignment(prop)) {
    44	      throw new Error(`Unsupported BEATS object member: ${ts.SyntaxKind[prop.kind]}`);
    45	    }
    46	    out[propertyName(prop.name)] = literalValue(prop.initializer);
    47	  }
    48	  return out;
    49	}
    50	
    51	function findBeatsSource(sourceFile) {
    52	  let beatsArray = null;
    53	
    54	  function visit(node) {
    55	    if (
    56	      ts.isVariableDeclaration(node) &&
    57	      ts.isIdentifier(node.name) &&
    58	      node.name.text === 'BEATS_SOURCE' &&
    59	      node.initializer
    60	    ) {
    61	      // BEATS_SOURCE = [...] as const
    62	      const init = ts.isAsExpression(node.initializer) ? node.initializer.expression : node.initializer;
    63	      if (ts.isArrayLiteralExpression(init)) {
    64	        beatsArray = init;
    65	        return;
    66	      }
    67	    }
    68	    ts.forEachChild(node, visit);
    69	  }
    70	
    71	  visit(sourceFile);
    72	
    73	  if (!beatsArray) {
    74	    throw new Error(`Could not find BEATS_SOURCE array in ${beatsSourcePath}`);
    75	  }
    76	
    77	  return beatsArray;
    78	}
    79	
    80	const beatsSourceText = await readFile(beatsSourcePath, 'utf8');
    81	
    82	const sourceFile = ts.createSourceFile(
    83	  beatsSourcePath,
    84	  beatsSourceText,
    85	  ts.ScriptTarget.Latest,
    86	  true,
    87	  ts.ScriptKind.TS,
    88	);
    89	const beats = findBeatsSource(sourceFile).elements.map(literalValue);
    90	
    91	// The opener is the first coach-bubble script line (the words the phone bubble
    92	// reads), else the first script line with words. The one source is script[].
    93	function firstOpener(beat) {
    94	  const bubble = beat.script?.find((line) => line.bindsTo?.kind === 'bubble' && line.words);
    95	  if (bubble) return bubble.words;
    96	  const line = beat.script?.find((l) => l.words);
    97	  return line ? line.words : null;
    98	}
    99	
   100	const exportBeats = beats.map((beat, index) => ({
   101	  index: index + 1,
   102	  id: beat.id,
   103	  opener: firstOpener(beat),
   104	  path: beat.path ?? null,
   105	}));
   106	
   107	await mkdir(path.dirname(outputPath), { recursive: true });
   108	await writeFile(
   109	  outputPath,
   110	  `${JSON.stringify(
   111	    {
   112	      source: {
   113	        beats: 'src/components/flow-designer/beatsSource.ts#BEATS_SOURCE',
   114	      },
   115	      beats: exportBeats,
   116	    },
   117	    null,
   118	    2,
   119	  )}\n`,
   120	);
   121	await writeFile(headersPath, headers);
   122	
   123	console.log(`Wrote ${path.relative(root, outputPath)} with ${exportBeats.length} beats`);
   124	console.log(`Wrote ${path.relative(root, headersPath)}`);

