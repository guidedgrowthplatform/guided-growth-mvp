   196	  for (const oldId of ['state-check', 'checkin', 'reflection', 'goal-custom', 'habit-custom', 'schedule', 'advanced-capture', 'advanced-frequency', 'plan']) {
   197	    const targetId = map.find((row) => row.oldId === oldId)?.targetId;
   198	    const io = targetById.get(targetId)?.io;
   199	    if (!io || !Array.isArray(io.dataIn) || !Array.isArray(io.dataOut)) fail(`coverage persistence: ${oldId}`);
   200	  }
   201	  for (const oldId of ['checkin', 'goal-custom', 'habit-custom']) {
   202	    const targetId = map.find((row) => row.oldId === oldId)?.targetId;
   203	    if (!targetById.get(targetId)?.bible?.allowedTools) fail(`coverage tools: ${oldId}`);
   204	  }
   205	  for (const oldId of ['weekly-blank', 'weekly-full', 'weekly-p78', 'weekly-p36', 'weekly-gaps']) {
   206	    const targetId = map.find((row) => row.oldId === oldId)?.targetId;
   207	    if (!targetById.get(targetId)?.bible?.components) fail(`coverage components: ${oldId}`);
   208	  }
   209	  checkNoLegacyConsumer();
   210	  console.log('Objective 1 verified: 62 beats, exactly 2 locked-copy deltas, rich contracts and coverage complete.');
   211	}
