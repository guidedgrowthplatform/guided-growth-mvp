     1	import { getBeatAllowedTools } from './beatContexts.js';
     2	import { ONBOARDING_TOOLS, type OnboardingToolDefinition } from './schemas.js';
     3	
     4	export function isOnboardingScreen(screenId: string | null | undefined): boolean {
     5	  return typeof screenId === 'string' && screenId.startsWith('ONBOARD-');
     6	}
     7	
     8	/**
     9	 * Tools the coach may call on a given onboarding beat.
    10	 *
    11	 * Per-beat gating (the fix for the wrong-tool-on-wrong-beat bug): each beat in
    12	 * beatContexts declares its `allowedTools`, and only those are exposed to the
    13	 * model. The route handler enforces it (a tool outside this set returns
    14	 * `unknown_tool`). Two fallbacks keep things safe:
    15	 *   - beat NOT in beatContexts (allowed === undefined): expose all tools (legacy
    16	 *     screens that have not been given an explicit allow-list yet).
    17	 *   - beat with an empty allow-list (e.g. the silent auth beat): expose none.
    18	 */
    19	export function getOnboardingTools(
    20	  screenId: string | null | undefined,
    21	): readonly OnboardingToolDefinition[] | undefined {
    22	  if (!isOnboardingScreen(screenId)) return undefined;
    23	  const allowed = getBeatAllowedTools(screenId as string);
    24	  if (allowed === undefined) return ONBOARDING_TOOLS;
    25	  const allowedSet = new Set<string>(allowed);
    26	  return ONBOARDING_TOOLS.filter((t) => allowedSet.has(t.name));
    27	}
