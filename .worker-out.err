   645	// Supabase, the hash/version travel with each row; for hand-authored content the
   646	// hash is computed here so it is always correct.
   647	
   648	/** Stable FNV-1a hash (deterministic, no crypto dep) of a beat's editable copy. */
   649	function fnv1a(input: string): string {
   650	  let h = 0x811c9dc5;
   651	  for (let i = 0; i < input.length; i++) {
   652	    h ^= input.charCodeAt(i);
   653	    h = Math.imul(h, 0x01000193);
   654	  }
   655	  return (h >>> 0).toString(16).padStart(8, '0');

