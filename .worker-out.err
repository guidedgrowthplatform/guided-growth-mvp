===== .github/actions/capacitor-build/action.yml
     1	name: Capacitor build
     2	description: Sync a native platform, brand the icon, generate assets (iOS also patches Info.plist).
     3	
     4	# Identity (APP_IDENTIFIER / APP_DISPLAY_NAME / CAP_EXTRA_NAV_HOSTS) is read from the
     5	# environment by capacitor.config.ts + patch-ios-plist.mjs. The caller MUST set these at
     6	# JOB level for iOS (step-level env on a `uses:` does not propagate into a composite).
     7	# iOS is regenerated each run (ios/ is gitignored) so it needs them; android/ is committed
     8	# (gradle `qa` flavor already carries the staging id + scheme), so Android sets nothing.
     9	
    10	inputs:
    11	  platform:
    12	    description: ios | android
    13	    required: true
    14	  icon-variant:
    15	    description: Passed to select-icon-master.mjs (qa | staging -> red QA icons).
    16	    required: true
    17	
    18	runs:
    19	  using: composite
    20	  steps:
    21	    - shell: bash
    22	      run: |
    23	        [ -d "${{ inputs.platform }}" ] || npx cap add ${{ inputs.platform }}
    24	        npx cap sync ${{ inputs.platform }}
    25	        node scripts/select-icon-master.mjs ${{ inputs.icon-variant }}
    26	        npx @capacitor/assets generate --${{ inputs.platform }} --assetPath assets
    27	
    28	    # generate rewrites Info.plist — patch the URL scheme after it.
    29	    - if: inputs.platform == 'ios'
    30	      shell: bash
    31	      run: node scripts/patch-ios-plist.mjs
===== .github/actions/setup-js-deps/action.yml
     1	name: Setup JS deps
     2	description: Node 22 + npm ci, plus optional sharp native rebuild (needed for @capacitor/assets).
     3	
     4	inputs:
     5	  rebuild-sharp:
     6	    description: Rebuild sharp's native binary (skip on web-only jobs that never run @capacitor/assets).
     7	    required: false
     8	    default: 'true'
     9	
    10	runs:
    11	  using: composite
    12	  steps:
    13	    - uses: actions/setup-node@v4
    14	      with:
    15	        node-version: '22'
    16	        cache: 'npm'
    17	
    18	    - shell: bash
    19	      run: npm ci --ignore-scripts
    20	
    21	    # --ignore-scripts skips sharp's native binary; libvips download flakes, so retry.
    22	    - if: inputs.rebuild-sharp == 'true'
    23	      shell: bash
    24	      run: |
    25	        for i in 1 2 3; do
    26	          npm rebuild sharp && exit 0
    27	          echo "sharp rebuild failed (attempt $i/3), retrying in 10s..."
    28	          sleep 10
    29	        done
    30	        exit 1
===== .github/workflows/ci.yml
     1	name: CI/CD Pipeline
     2	
     3	# ─────────────────────────────────────────────────────────────────────────────
     4	# Required secrets for the ios-testflight job (Settings → Secrets → Actions):
     5	#   ASC_KEY_ID                       — App Store Connect API key ID
     6	#   ASC_ISSUER_ID                    — App Store Connect issuer ID (UUID)
     7	#   ASC_KEY_CONTENT                  — base64-encoded .p8 contents
     8	#   MATCH_GIT_URL                    — SSH URL of private match repo (git@…)
     9	#   MATCH_PASSWORD                   — encryption password for match repo
    10	#   MATCH_DEPLOY_KEY                 — SSH private key authorized on match repo
    11	#   VITE_SUPABASE_URL                — baked into the iOS bundle at build time
    12	#   VITE_SUPABASE_ANON_KEY           — baked into the iOS bundle at build time
    13	#   VITE_VAPI_PUBLIC_KEY             — Vapi realtime voice (required for onboarding)
    14	#   VITE_VAPI_ASSISTANT_ID           — Vapi assistant id (required for onboarding)
    15	#   VITE_CARTESIA_AGENT_ID           — voice agent (optional but recommended)
    16	#   VITE_STATE3_ENABLED              — enable Path 3 State 3 Soniox streaming (true/false)
    17	#   VITE_POSTHOG_KEY                 — analytics (optional)
    18	#   VITE_SENTRY_DSN                  — error tracking (optional)
    19	#
    20	# Required secrets for the build-apk job (Android Play Store release):
    21	#   ANDROID_KEYSTORE_BASE64          — base64-encoded upload keystore
    22	#   ANDROID_KEYSTORE_PASSWORD        — keystore password
    23	#   ANDROID_KEY_ALIAS                — signing key alias
    24	#   ANDROID_KEY_PASSWORD             — signing key password
    25	#   SERVICE_ACCOUNT_JSON             — Play Console service account JSON
    26	#   MATTERMOST_ANDROID_CI_WEBHOOK_URL — Mattermost incoming webhook (release notify; optional)
    27	#   FIREBASE_APP_ID                  — Firebase Android app id (App Distribution; optional)
    28	#   FIREBASE_SERVICE_ACCOUNT_JSON    — service account JSON w/ Firebase App Distribution Admin
    29	#
    30	# Repository variables (Settings → Variables → Actions):
    31	#   SKIP_TESTFLIGHT                  — default builds iOS TestFlight; set to 'true' to skip
    32	# ─────────────────────────────────────────────────────────────────────────────
    33	
    34	on:
    35	  push:
    36	    branches: ['main', 'fix/android-apk-server-access']
    37	    tags: ['v*']
    38	  pull_request:
    39	    branches: ['main']
    40	  workflow_dispatch:
    41	
    42	jobs:
    43	  validate-and-test:
    44	    runs-on: ubuntu-latest
    45	    steps:
    46	      - name: Checkout repository
    47	        uses: actions/checkout@v4
    48	
    49	      - name: Setup Node.js
    50	        uses: actions/setup-node@v4
    51	        with:
    52	          node-version: '22'
    53	          cache: 'npm'
    54	
    55	      - name: Install dependencies
    56	        run: npm ci --ignore-scripts
    57	
    58	      - name: Verify icon bundle is up to date
    59	        run: |
    60	          npm run icons:bundle
    61	          git diff --exit-code src/generated/icon-bundle.json
    62	
    63	      - name: Lint
    64	        continue-on-error: true
    65	        run: |
    66	          npm run lint
    67	          npm run format:check
    68	
    69	      - name: Type check
    70	        run: npm run type-check
    71	
    72	      - name: Test
    73	        run: npm run test:coverage
    74	
    75	      - name: Upload coverage
    76	        uses: actions/upload-artifact@v4
    77	        with:
    78	          name: coverage-report
    79	          path: coverage/
    80	
    81	      - name: Security audit
    82	        continue-on-error: true
    83	        run: npm audit --audit-level=critical
    84	
    85	  build:
    86	    runs-on: ubuntu-latest
    87	    needs: validate-and-test
    88	    steps:
    89	      - name: Checkout repository
    90	        uses: actions/checkout@v4
    91	
    92	      - name: Setup Node.js
    93	        uses: actions/setup-node@v4
    94	        with:
    95	          node-version: '22'
    96	          cache: 'npm'
    97	
    98	      - name: Install dependencies
    99	        run: npm ci --ignore-scripts
   100	
   101	      - name: Build web
   102	        env:
   103	          VITE_API_URL: 'https://guided-growth-mvp.vercel.app'
   104	          VITE_SUPABASE_URL: ${{ secrets.VITE_SUPABASE_URL }}
   105	          VITE_SUPABASE_ANON_KEY: ${{ secrets.VITE_SUPABASE_ANON_KEY }}
   106	          VITE_VAPI_PUBLIC_KEY: ${{ secrets.VITE_VAPI_PUBLIC_KEY }}
   107	          VITE_VAPI_ASSISTANT_ID: ${{ secrets.VITE_VAPI_ASSISTANT_ID }}
   108	          VITE_CARTESIA_AGENT_ID: ${{ secrets.VITE_CARTESIA_AGENT_ID }}
   109	          VITE_STATE3_ENABLED: ${{ secrets.VITE_STATE3_ENABLED }}
   110	          VITE_POSTHOG_KEY: ${{ secrets.VITE_POSTHOG_KEY }}
   111	          VITE_SENTRY_DSN: ${{ secrets.VITE_SENTRY_DSN }}
   112	        run: npm run build
   113	
   114	      - name: Upload build artifacts
   115	        uses: actions/upload-artifact@v4
   116	        with:
   117	          name: dist
   118	          path: dist/
   119	          retention-days: 7
   120	
   121	  build-apk:
   122	    name: Build Android App Bundle (Release)
   123	    runs-on: ubuntu-latest
   124	    needs: build
   125	    if: >-
   126	      github.event_name == 'workflow_dispatch'
   127	      || (github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v'))
   128	    concurrency:
   129	      group: android-release-${{ github.ref }}
   130	      cancel-in-progress: false
   131	    steps:
   132	      - name: Checkout repository
   133	        uses: actions/checkout@v4
   134	
   135	      - name: Setup Java
   136	        uses: actions/setup-java@v4
   137	        with:
   138	          distribution: 'temurin'
   139	          java-version: '21'
   140	
   141	      - name: Setup Node.js
   142	        uses: actions/setup-node@v4
   143	        with:
   144	          node-version: '22'
   145	          cache: 'npm'
   146	
   147	      - name: Install dependencies
   148	        run: npm ci --ignore-scripts
   149	
   150	      - name: Build sharp native binary
   151	        # libvips download from GitHub releases flakes; retry before failing.
   152	        run: |
   153	          for i in 1 2 3; do
   154	            npm rebuild sharp && exit 0
   155	            echo "sharp rebuild failed (attempt $i/3), retrying in 10s..."
   156	            sleep 10
   157	          done
   158	          exit 1
   159	
   160	      - name: Download web build artifact
   161	        uses: actions/download-artifact@v4
   162	        with:
   163	          name: dist
   164	          path: dist
   165	
   166	      - name: Add Android platform and copy web assets
   167	        run: |
   168	          [ -d android ] || npx cap add android
   169	          npx cap copy android
   170	          npx cap sync android
   171	          npx @capacitor/assets generate --android --assetPath assets
   172	
   173	      - name: Decode Keystore
   174	        env:
   175	          KEYSTORE_BASE64: ${{ secrets.ANDROID_KEYSTORE_BASE64 }}
   176	        run: |
   177	          printf '%s' "$KEYSTORE_BASE64" | base64 -d > android/app/guidedgrowth.keystore
   178	
   179	      # bundleProdRelease -> AAB for Play; assembleProdRelease -> APK for Firebase.
   180	      - name: Build Release AAB + APK
   181	        working-directory: android
   182	        env:
   183	          KEYSTORE_FILE: 'guidedgrowth.keystore'
   184	          KEYSTORE_PASSWORD: ${{ secrets.ANDROID_KEYSTORE_PASSWORD }}
   185	          KEYSTORE_ALIAS: ${{ secrets.ANDROID_KEY_ALIAS }}
   186	          KEY_PASSWORD: ${{ secrets.ANDROID_KEY_PASSWORD }}
   187	        run: |
   188	          chmod +x gradlew
   189	          ./gradlew bundleProdRelease assembleProdRelease --no-daemon \
   190	            -PversionCode=${{ github.run_number }} \
   191	            -PversionName=${{ github.ref_name }}
   192	
   193	      - name: Upload AAB artifact
   194	        id: upload_aab
   195	        uses: actions/upload-artifact@v4
   196	        with:
   197	          name: guided-growth-aab
   198	          path: android/app/build/outputs/bundle/prodRelease/*.aab
   199	          retention-days: 14
   200	
   201	      # Play caps release notes at 500 chars/locale — fail early, not mid-upload.
   202	      - name: Validate Play release notes length
   203	        if: >-
   204	          github.event_name == 'push'
   205	          && startsWith(github.ref, 'refs/tags/v')
   206	        run: |
   207	          f=release-notes/whatsnew-en-US
   208	          [ -f "$f" ] || { echo "::error::Missing $f"; exit 1; }
   209	          len=$(wc -m < "$f" | tr -d ' ')
   210	          echo "Release notes length: $len chars"
   211	          if [ "$len" -gt 500 ]; then
   212	            echo "::error::Play release notes exceed 500 chars ($len). Trim $f."
   213	            exit 1
   214	          fi
   215	
   216	      - name: Deploy to Google Play (internal track)
   217	        if: >-
   218	          github.event_name == 'push'
   219	          && startsWith(github.ref, 'refs/tags/v')
   220	        uses: r0adkll/upload-google-play@v1
   221	        with:
   222	          serviceAccountJsonPlainText: ${{ secrets.SERVICE_ACCOUNT_JSON }}
   223	          packageName: app.guidedgrowth.mvp
   224	          releaseFiles: android/app/build/outputs/bundle/prodRelease/app-prod-release.aab
   225	          track: internal
   226	          whatsNewDirectory: release-notes
   227	
   228	      # TestFlight-equivalent: emails the tester group an install link per
   229	      # tagged release. Skips silently when FIREBASE_APP_ID is unset so the
   230	      # release never reds before Firebase is configured.
   231	      - name: Distribute to Firebase App Distribution
   232	        if: >-
   233	          github.event_name == 'push'
   234	          && startsWith(github.ref, 'refs/tags/v')
   235	          && env.FIREBASE_APP_ID != ''
   236	        env:
   237	          FIREBASE_APP_ID: ${{ secrets.FIREBASE_APP_ID }}
   238	        uses: wzieba/Firebase-Distribution-Github-Action@v1
   239	        with:
   240	          appId: ${{ secrets.FIREBASE_APP_ID }}
===== .github/workflows/match-bootstrap.yml
     1	name: Bootstrap match repo (one-shot)
     2	
     3	# Manual-only workflow that populates the match-certificates repo with a
     4	# fresh distribution certificate + appstore provisioning profile via
     5	# fastlane match. Designed to be run exactly once for initial setup, or
     6	# whenever the match repo is empty/nuked.
     7	#
     8	# Prerequisites:
     9	#   1. Grant WRITE permission to MATCH_DEPLOY_KEY on the match repo
    10	#      (gitlab.com/guidedgrowth-group/match-certificates → Settings →
    11	#      Repository → Deploy Keys → tick "Grant write permissions").
    12	#   2. Trigger this workflow manually from the Actions tab.
    13	#   3. After it completes successfully, REVOKE the write permission.
    14	#
    15	# This workflow never fires on push — only via workflow_dispatch.
    16	
    17	on:
    18	  workflow_dispatch:
    19	    inputs:
    20	      app_identifier:
    21	        description: 'Bundle ID to bootstrap (e.g. app.guidedgrowth.staging)'
    22	        required: true
    23	        default: 'app.guidedgrowth.mvp'
    24	
    25	jobs:
    26	  bootstrap-match:
    27	    name: Generate cert + profile, push to match repo
    28	    runs-on: macos-26
    29	    steps:
    30	      - name: Checkout repository
    31	        uses: actions/checkout@v4
    32	
    33	      - name: Load match SSH deploy key
    34	        uses: webfactory/ssh-agent@v0.9.0
    35	        with:
    36	          ssh-private-key: ${{ secrets.MATCH_DEPLOY_KEY }}
    37	
    38	      - name: Trust git hosts (avoid host-key prompt hanging the clone)
    39	        run: |
    40	          mkdir -p ~/.ssh
    41	          ssh-keyscan -H github.com gitlab.com >> ~/.ssh/known_hosts 2>/dev/null
    42	          chmod 600 ~/.ssh/known_hosts
    43	
    44	      - name: Setup Ruby + Bundler cache
    45	        uses: ruby/setup-ruby@v1
    46	        with:
    47	          ruby-version: '3.3'
    48	          bundler-cache: true
    49	
    50	      - name: Run match in write mode
    51	        env:
    52	          APP_IDENTIFIER: ${{ inputs.app_identifier }}
    53	          ASC_KEY_ID: ${{ secrets.ASC_KEY_ID }}
    54	          ASC_ISSUER_ID: ${{ secrets.ASC_ISSUER_ID }}
    55	          ASC_KEY_CONTENT: ${{ secrets.ASC_KEY_CONTENT }}
    56	          MATCH_GIT_URL: ${{ secrets.MATCH_GIT_URL }}
    57	          MATCH_PASSWORD: ${{ secrets.MATCH_PASSWORD }}
    58	        run: bundle exec fastlane ios bootstrap_match
===== .github/workflows/qa-release.yml
     1	name: QA Release (Staging — iOS + Android)
     2	
     3	# ─────────────────────────────────────────────────────────────────────────────
     4	# Single QA pipeline for the staging app (app.guidedgrowth.staging):
     5	#   • iOS    → TestFlight (fastlane match + ASC API key)
     6	#   • Android→ Firebase App Distribution (internal-testers group)
     7	#
     8	# Trigger: push a `qa-v*` tag (e.g. qa-v2.9.3 → marketing version 2.9.3). Does NOT
     9	# match ci.yml's `v*` glob, so prod releases never fire from a QA tag. Manual
    10	# workflow_dispatch is kept as an escape hatch (pass `version` for a clean number).
    11	#
    12	# DATA-DRIVEN by the `staging` GitHub Environment (Settings → Environments):
    13	#   Variables: APP_IDENTIFIER, APP_DISPLAY_NAME, VITE_API_URL, CAP_EXTRA_NAV_HOSTS, MATCH_GIT_BRANCH
    14	#   Secrets:   VITE_* + ASC_* + MATCH_* + APPLE_TEAM_ID (inherit from repo level)
    15	# Android signing + Firebase secrets are repo-level:
    16	#   ANDROID_KEYSTORE_BASE64/PASSWORD, ANDROID_KEY_ALIAS/PASSWORD,
    17	#   FIREBASE_APP_ID_QA, FIREBASE_SERVICE_ACCOUNT_JSON
    18	# ─────────────────────────────────────────────────────────────────────────────
    19	
    20	on:
    21	  push:
    22	    tags: ['qa-v*']
    23	  workflow_dispatch:
    24	    inputs:
    25	      version:
    26	        description: 'Semver marketing version (e.g. 2.9.2). REQUIRED on tagless dispatch — resolve-version fails on non-semver so iOS and Android always ship the same version.'
    27	        type: string
    28	        required: false
    29	        default: ''
    30	
    31	concurrency:
    32	  group: qa-release-${{ github.ref }}
    33	  cancel-in-progress: false
    34	
    35	jobs:
    36	  resolve-version:
    37	    name: Resolve QA version
    38	    runs-on: ubuntu-latest
    39	    outputs:
    40	      version: ${{ steps.v.outputs.version }}
    41	    steps:
    42	      - id: v
    43	        run: |
    44	          if [[ "$GITHUB_REF" == refs/tags/qa-v* ]]; then
    45	            v="${GITHUB_REF_NAME#qa-v}"          # qa-v2.9.3 -> 2.9.3
    46	          elif [ -n "${{ inputs.version }}" ]; then
    47	            v="${{ inputs.version }}"
    48	          else
    49	            v="qa-${{ github.run_number }}"
    50	          fi
    51	          echo "Resolved QA version: $v"
    52	          # Fastfile only bumps iOS on a semver match; non-semver would ship
    53	          # iOS 1.0.0 while Android ships "$v" — fail before any build starts.
    54	          if [[ ! "$v" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+ ]]; then
    55	            echo "::error::Version '$v' is not semver — iOS would ship 1.0.0 while Android ships '$v'. Pass a semver 'version' on dispatch, or use a qa-v* tag."
    56	            exit 1
    57	          fi
    58	          echo "version=$v" >> "$GITHUB_OUTPUT"
    59	
    60	  web-build:
    61	    name: Build web (staging)
    62	    runs-on: ubuntu-latest
    63	    environment: staging
    64	    steps:
    65	      - uses: actions/checkout@v4
    66	
    67	      - uses: ./.github/actions/setup-js-deps
    68	        with:
    69	          rebuild-sharp: 'false'
    70	
    71	      - name: Build web
    72	        env:
    73	          APP_IDENTIFIER: ${{ vars.APP_IDENTIFIER }}
    74	          APP_DISPLAY_NAME: ${{ vars.APP_DISPLAY_NAME }}
    75	          VITE_API_URL: ${{ vars.VITE_API_URL }}
    76	          VITE_SUPABASE_URL: ${{ secrets.VITE_SUPABASE_URL }}
    77	          VITE_SUPABASE_ANON_KEY: ${{ secrets.VITE_SUPABASE_ANON_KEY }}
    78	          VITE_VAPI_PUBLIC_KEY: ${{ secrets.VITE_VAPI_PUBLIC_KEY }}
    79	          VITE_VAPI_ASSISTANT_ID: ${{ secrets.VITE_VAPI_ASSISTANT_ID }}
    80	          VITE_CARTESIA_AGENT_ID: ${{ secrets.VITE_CARTESIA_AGENT_ID }}
    81	          VITE_STATE3_ENABLED: ${{ secrets.VITE_STATE3_ENABLED }}
    82	          VITE_POSTHOG_KEY: ${{ secrets.VITE_POSTHOG_KEY }}
    83	          VITE_SENTRY_DSN: ${{ secrets.VITE_SENTRY_DSN }}
    84	        run: npm run build
    85	
    86	      - uses: actions/upload-artifact@v4
    87	        with:
    88	          name: dist-staging
    89	          path: dist/
    90	          retention-days: 7
    91	
    92	  android-qa:
    93	    name: Build QA APK → Firebase
    94	    runs-on: ubuntu-latest
    95	    environment: staging
    96	    needs: [resolve-version, web-build]
    97	    # job-level so the Firebase step's `if` can read it (step env is out of scope there)
    98	    env:
    99	      FIREBASE_APP_ID_QA: ${{ secrets.FIREBASE_APP_ID_QA }}
   100	    steps:
   101	      - uses: actions/checkout@v4
   102	
   103	      - name: Setup Java
   104	        uses: actions/setup-java@v4
   105	        with:
   106	          distribution: 'temurin'
   107	          java-version: '21'
   108	
   109	      - uses: ./.github/actions/setup-js-deps
   110	
   111	      - name: Download web build artifact
   112	        uses: actions/download-artifact@v4
   113	        with:
   114	          name: dist-staging
   115	          path: dist
   116	
   117	      # android/ is committed (gradle `qa` flavor carries the staging id + scheme);
   118	      # no APP_* identity needed here.
   119	      - uses: ./.github/actions/capacitor-build
   120	        with:
   121	          platform: android
   122	          icon-variant: qa
   123	
   124	      - name: Decode Keystore
   125	        env:
   126	          KEYSTORE_BASE64: ${{ secrets.ANDROID_KEYSTORE_BASE64 }}
   127	        run: |
   128	          printf '%s' "$KEYSTORE_BASE64" | base64 -d > android/app/guidedgrowth.keystore
   129	
   130	      - name: Build QA APK
   131	        working-directory: android
   132	        env:
   133	          KEYSTORE_FILE: 'guidedgrowth.keystore'
   134	          KEYSTORE_PASSWORD: ${{ secrets.ANDROID_KEYSTORE_PASSWORD }}
   135	          KEYSTORE_ALIAS: ${{ secrets.ANDROID_KEY_ALIAS }}
   136	          KEY_PASSWORD: ${{ secrets.ANDROID_KEY_PASSWORD }}
   137	          # via env so the version string can't break shell quoting
   138	          VERSION_NAME: ${{ needs.resolve-version.outputs.version }}
   139	        run: |
   140	          chmod +x gradlew
   141	          ./gradlew assembleQaRelease --no-daemon \
   142	            -PversionCode=${{ github.run_number }} \
   143	            -PversionName="$VERSION_NAME"
   144	
   145	      - name: Upload QA APK artifact
   146	        uses: actions/upload-artifact@v4
   147	        with:
   148	          name: guided-growth-qa-apk
   149	          path: android/app/build/outputs/apk/qa/release/app-qa-release.apk
   150	          retention-days: 14
   151	
   152	      # skips silently when FIREBASE_APP_ID_QA unset
   153	      - name: Distribute QA to Firebase App Distribution
   154	        if: env.FIREBASE_APP_ID_QA != ''
   155	        uses: wzieba/Firebase-Distribution-Github-Action@v1
   156	        with:
   157	          appId: ${{ secrets.FIREBASE_APP_ID_QA }}
   158	          serviceCredentialsFileContent: ${{ secrets.FIREBASE_SERVICE_ACCOUNT_JSON }}
   159	          groups: internal-testers
   160	          file: android/app/build/outputs/apk/qa/release/app-qa-release.apk
   161	          releaseNotes: ${{ needs.resolve-version.outputs.version }}
   162	
   163	  ios-qa:
   164	    name: Build QA IPA → TestFlight
   165	    runs-on: macos-26
   166	    environment: staging
   167	    needs: [resolve-version, web-build]
   168	    # job-level so identity reaches the capacitor-build composite's steps
   169	    # (step-level env on a `uses:` does NOT propagate into a composite).
   170	    env:
   171	      APP_IDENTIFIER: ${{ vars.APP_IDENTIFIER }}
   172	      APP_DISPLAY_NAME: ${{ vars.APP_DISPLAY_NAME }}
   173	      CAP_EXTRA_NAV_HOSTS: ${{ vars.CAP_EXTRA_NAV_HOSTS }}
   174	    steps:
   175	      - uses: actions/checkout@v4
   176	
   177	      - name: Load match SSH deploy key
   178	        uses: webfactory/ssh-agent@v0.9.0
   179	        with:
   180	          ssh-private-key: ${{ secrets.MATCH_DEPLOY_KEY }}
   181	
   182	      - name: Trust git hosts (avoid host-key prompt hanging the clone)
   183	        run: |
   184	          mkdir -p ~/.ssh
   185	          ssh-keyscan -H github.com gitlab.com >> ~/.ssh/known_hosts 2>/dev/null
   186	          chmod 600 ~/.ssh/known_hosts
   187	
   188	      - name: Setup Ruby + Bundler cache
   189	        uses: ruby/setup-ruby@v1
   190	        with:
   191	          ruby-version: '3.3'
   192	          bundler-cache: true
   193	
   194	      - uses: ./.github/actions/setup-js-deps
   195	
   196	      - name: Download web build artifact
   197	        uses: actions/download-artifact@v4
   198	        with:
   199	          name: dist-staging
   200	          path: dist
   201	
   202	      # Fail loud if tester notes are missing — a build with blank "What to
   203	      # Test" defeats the point. TestFlight caps What-to-Test at 4000 chars.
   204	      - name: Validate iOS release notes present
   205	        run: |
   206	          f=release-notes/whatsnew-en-US
   207	          [ -s "$f" ] || { echo "::error::Missing or empty $f — testers need release notes."; exit 1; }
   208	          len=$(wc -m < "$f" | tr -d ' ')
   209	          echo "Release notes length: $len chars"
   210	          if [ "$len" -gt 4000 ]; then
   211	            echo "::error::TestFlight What-to-Test exceeds 4000 chars ($len). Trim $f."
   212	            exit 1
   213	          fi
   214	
   215	      - uses: ./.github/actions/capacitor-build
   216	        with:
   217	          platform: ios
   218	          icon-variant: staging
   219	
   220	      - name: Build IPA & upload to TestFlight (fastlane)
   221	        env:
   222	          APP_VERSION: ${{ needs.resolve-version.outputs.version }}
   223	          MATCH_GIT_BRANCH: ${{ vars.MATCH_GIT_BRANCH }}
   224	          ASC_KEY_ID: ${{ secrets.ASC_KEY_ID }}
   225	          ASC_ISSUER_ID: ${{ secrets.ASC_ISSUER_ID }}
   226	          ASC_KEY_CONTENT: ${{ secrets.ASC_KEY_CONTENT }}
   227	          MATCH_GIT_URL: ${{ secrets.MATCH_GIT_URL }}
   228	          MATCH_PASSWORD: ${{ secrets.MATCH_PASSWORD }}
   229	          APPLE_TEAM_ID: ${{ secrets.APPLE_TEAM_ID }}
   230	        run: bundle exec fastlane ios beta
   231	
   232	      - name: Upload IPA artifact (debug)
   233	        if: always()
   234	        uses: actions/upload-artifact@v4
   235	        with:
   236	          name: ios-ipa-staging
   237	          path: build/ios/*.ipa
   238	          retention-days: 14
   239	          if-no-files-found: warn
===== .github/workflows/voice-sync.yml
     1	name: voice-sync
     2	
     3	on:
     4	  workflow_dispatch:
     5	    inputs:
     6	      dry_run:
     7	        type: boolean
     8	        default: false
     9	        description: "Read sheet + compute diff, skip all DB writes"
    10	  schedule:
    11	    - cron: '0 * * * *'
    12	
    13	permissions: {}
    14	
    15	concurrency:
    16	  group: voice-sync
    17	  cancel-in-progress: false
    18	
    19	jobs:
    20	  sync:
    21	    runs-on: ubuntu-latest
    22	    timeout-minutes: 5
    23	    steps:
    24	      - uses: actions/checkout@v4
    25	
    26	      - uses: actions/setup-python@v5
    27	        with:
    28	          python-version: '3.11'
    29	          cache: 'pip'
    30	          cache-dependency-path: scripts/voice-sync/requirements.txt
    31	
    32	      - name: Install deps
    33	        run: pip install -r scripts/voice-sync/requirements.txt
    34	
    35	      - name: Unit tests
    36	        working-directory: scripts/voice-sync
    37	        run: pytest tests/
    38	
    39	      - name: Stage GCP service-account file
    40	        env:
    41	          SA_JSON: ${{ secrets.GOOGLE_SERVICE_ACCOUNT_JSON }}
    42	        run: |
    43	          printf '%s' "$SA_JSON" > "$RUNNER_TEMP/sa.json"
    44	          echo "GOOGLE_APPLICATION_CREDENTIALS=$RUNNER_TEMP/sa.json" >> "$GITHUB_ENV"
    45	
    46	      - name: Run seed_contexts
    47	        env:
    48	          DRY_RUN: ${{ inputs.dry_run }}
    49	          GOOGLE_SHEET_ID: ${{ secrets.GOOGLE_SHEET_ID }}
    50	          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
    51	          SUPABASE_SERVICE_ROLE_KEY: ${{ secrets.SUPABASE_SERVICE_ROLE_KEY }}
    52	        run: |
    53	          set -euo pipefail
    54	          if [ "$DRY_RUN" = "true" ]; then
    55	            python scripts/voice-sync/seed_contexts.py --dry-run | tee -a "$GITHUB_STEP_SUMMARY"
    56	          else
    57	            python scripts/voice-sync/seed_contexts.py | tee -a "$GITHUB_STEP_SUMMARY"
    58	          fi
