/home/ggvoice/gg-ground/gg-mvp/api/_lib/llm/onboarding/preconditions.ts
     1	import pool from '../../../db.js';
     2	import type { ToolResult } from '../../tools.js';
     3	import { checkAdvanceData, traceAdvanceStep0 } from '../preconditions.js';
     4	import { getNumber, handlerError, invalid, ok, type OnboardingHandlerCtx } from './shared.js';
     5	
     6	const MIN_STEP = 1;
     7	const MAX_STEP = 10;
     8	
     9	// Only tool that writes current_step. Bare-set (no GREATEST) so back-nav forward re-fires useAgentNavigation.
    10	export async function advanceStep(
    11	  ctx: OnboardingHandlerCtx,
    12	  args: Record<string, unknown>,
    13	): Promise<ToolResult> {
    14	  const targetStep = getNumber(args, 'target_step');
    15	  if (targetStep === undefined || !Number.isInteger(targetStep)) {
    16	    return invalid('target_step must be an integer');
    17	  }
    18	  if (targetStep < MIN_STEP || targetStep > MAX_STEP) {
    19	    return invalid(`target_step must be between ${MIN_STEP} and ${MAX_STEP}`);
    20	  }
    21	
    22	  const existing = await pool.query<{
    23	    current_step: number;
    24	    data: Record<string, unknown> | null;
    25	    path: string | null;
    26	    brain_dump_raw: string | null;
    27	  }>(`SELECT current_step, data, path, brain_dump_raw FROM onboarding_states WHERE anon_id = $1`, [
    28	    ctx.anon_id,
    29	  ]);
    30	  const row = existing.rows[0];
    31	  const currentStep = row?.current_step ?? 1;
    32	  const data = (row?.data ?? {}) as Record<string, unknown>;
    33	  const path = row?.path ?? null;
    34	  const brainDumpRaw = row?.brain_dump_raw ?? null;
    35	
    36	  // Jumps beyond +2 are genuine skips → reject. Same step / back-nav allowed.
    37	  if (targetStep > currentStep + 2) {
    38	    return handlerError(
    39	      `cannot_skip_steps: current_step=${currentStep}, target_step=${targetStep}. Advance one step at a time.`,
    40	    );
    41	  }
    42	
    43	  // +2 is a tap/voice catch-up: tap-navigation into the current screen does NOT
    44	  // bump current_step, so a subsequent agent advance lands two ahead. Allow it
    45	  // ONLY when BOTH steps being left already have their data saved.
    46	  if (targetStep === currentStep + 2) {
    47	    for (let s = currentStep; s < targetStep; s++) {
    48	      if (checkAdvanceData({ sourceStep: s, data, path, brainDumpRaw })) {
    49	        return handlerError(
    50	          `cannot_skip_steps: current_step=${currentStep}, target_step=${targetStep}. Advance one step at a time.`,
    51	        );
    52	      }
    53	    }
    54	  }
    55	
    56	  // Forward advance — the source screen's data must be saved.
    57	  if (targetStep === currentStep + 1) {
    58	    const missing = checkAdvanceData({ sourceStep: currentStep, data, path, brainDumpRaw });
    59	    if (missing) return handlerError(missing);
    60	  }
    61	
    62	  traceAdvanceStep0('direct', { currentStep, targetStep, data, path, brainDumpRaw });
    63	
    64	  const result = await pool.query<{ current_step: number }>(
    65	    `INSERT INTO onboarding_states (anon_id, current_step, status, updated_at)
    66	     VALUES ($1, $2, 'in_progress', now())
    67	     ON CONFLICT (anon_id) DO UPDATE SET
    68	       current_step = $2,
    69	       status = 'in_progress',
    70	       updated_at = now()
    71	     RETURNING current_step`,
    72	    [ctx.anon_id, targetStep],
    73	  );
    74	
    75	  return ok({ current_step: result.rows[0]?.current_step ?? targetStep });
    76	}
     1	// Onboarding advance/finalize data guards. checkAdvanceData is shared by the
     2	// Direct-LLM advance_step handler AND Vapi's navigate_next (see
     3	// api/_lib/vapi/handlers/navigateNext.ts), so a gate change here applies to
     4	// both voice lanes.
     5	import { ADVANCE_GATE_OWNERS, STEP_OWNERS } from './stepMaps.generated.js';
     6	
     7	type Gate = (
     8	  data: Record<string, unknown>,
     9	  path: string | null,
    10	  brainDumpRaw: string | null,
    11	) => string | null;
    12	
    13	const habitsGate: Gate = (data) => {
    14	  const habits = data.habitConfigs as Record<string, unknown> | undefined;
    15	  if (!habits || Object.keys(habits).length === 0) {
    16	    return 'habits_missing: call add_habit at least once first';
    17	  }
    18	  return null;
    19	};
    20	
    21	// Step 3 on either lane: category (beginner) or the brain dump (advanced) counts.
    22	const categoryOrBrainDumpGate: Gate = (data, _path, brainDumpRaw) => {
    23	  if (!data.category && !(typeof brainDumpRaw === 'string' && brainDumpRaw.length > 0)) {
    24	    return 'category_or_braindump_missing: call submit_category (beginner) or submit_brain_dump (advanced) first';
    25	  }
    26	  return null;
    27	};
    28	
    29	// Data gate per beat componentType. WHICH beat gates a step comes from the
    30	// generated flow (STEP_OWNERS); gate wording is owned by the context lane.
    31	const GATES: Record<string, Gate> = {
    32	  'profile-input': (data) => {
    33	    // nickname captured at auth; this beat gates on age+gender only.
    34	    if (!data.age) return 'age_missing: call submit_profile with age first';
    35	    if (!data.gender)
    36	      return 'gender_missing: call submit_profile with gender (Male | Female | Other) — gender is required and cannot be skipped';
    37	    return null;
    38	  },
    39	  'path-selection': (_data, path) => (!path ? 'path_missing: call submit_path_choice first' : null),
    40	  'category-grid': categoryOrBrainDumpGate,
    41	  'advanced-capture': categoryOrBrainDumpGate,
    42	  'goals-list': (data) => {
    43	    if (!Array.isArray(data.goals) || data.goals.length === 0) {
    44	      return 'goals_missing: call submit_goals first (with the chosen goals)';
    45	    }
    46	    return null;
    47	  },
    48	  // Advanced-frequency schedules the parsed habits — gate on habitConfigs, not goals.
    49	  'advanced-frequency': habitsGate,
    50	  'habit-picker': habitsGate,
    51	  'habit-schedule': habitsGate,
    52	  'state-check': (data) => {
    53	    // record_checkin (voice) writes stateCheck; the card tap writes checkin.
    54	    if (!data.stateCheck && !data.checkin) {
    55	      return 'state_check_missing: call record_checkin first (at least one of sleep/mood/energy/stress)';
    56	    }
    57	    return null;
    58	  },
    59	  // B58 follow-up: an explicit refusal (config_refused_by_user) persists
    60	  // morningCheckinSkipped=true as a terminal answer — without a skip path the
    61	  // beat is inescapable and the model retries submit_morning_checkin on later
    62	  // turns, where unrelated time/day content can slip past the guard and save a
    63	  // config the user already declined.
    64	  'morning-checkin-setup': (data) =>
    65	    !data.morningCheckin && data.morningCheckinSkipped !== true
    66	      ? 'morning_checkin_missing: call submit_morning_checkin first'
    67	      : null,
    68	  'reflection-card': (data) =>
    69	    !data.reflectionConfig ? 'reflection_missing: call submit_reflection_config first' : null,
    70	  'weekly-day-picker': (data) =>
    71	    !data.weeklyConfig ? 'weekly_config_missing: call submit_weekly_config first' : null,
    72	};
    73	
    74	// Per-step data preconditions for a FORWARD advance (sourceStep → sourceStep+1).
    75	// Returns the missing-field message, or null if the precondition passes. Back-nav
    76	// (target <= current) is always allowed — callers only check forward advances.
    77	// The step→beat table is derived from the generated flow (L1-3); the V3 scale
    78	// stays non-monotonic vs flow order (1,6,7,8,9,2,3,4,5,5 — identities, not
    79	// positions). Steps past the scale (legacy 10+ ids) have no V3 beat: nothing to gate.
    80	export function checkAdvanceData(args: {
    81	  sourceStep: number;
    82	  data: Record<string, unknown>;
    83	  path: string | null;
    84	  brainDumpRaw: string | null;
    85	}): string | null {
    86	  const { sourceStep, data, path, brainDumpRaw } = args;
    87	  const advanced = path === 'braindump' || path === 'advanced';
    88	  // The stored step runs one AHEAD of the identity scale across shared persist
    89	  // steps (habit-select + habit-schedule both persist 5, so habit-schedule is
    90	  // stored as 6). Gate on the beat actually being LEFT at this stored step
    91	  // (ADVANCE_GATE_OWNERS, lane-aware), falling back to the identity owner where
    92	  // no window beat displays there. B50: the old identity-only lookup gated the
    93	  // habit-schedule advance (6 to 7) on state-check data, which cannot exist yet
    94	  // (state-check is the NEXT beat), telling the model to call record_checkin on
    95	  // a beat where that tool is not exposed. Cornered, it rerouted the check-in
    96	  // into add_habit and hit max_habits_reached ("habit limit reached").
    97	  const laneKey = advanced ? 'braindump' : 'simple';
    98	  const gateOwner = ADVANCE_GATE_OWNERS[sourceStep]?.[laneKey];
    99	  const owners = STEP_OWNERS[sourceStep];
   100	  const identityOwner = owners
   101	    ? advanced
   102	      ? (owners.braindump ?? owners.simple)
   103	      : (owners.simple ?? owners.braindump)
   104	    : undefined;
   105	  const component = gateOwner ?? identityOwner;
   106	  const gate = component ? GATES[component] : undefined;
   107	  return gate ? gate(data, path, brainDumpRaw) : null;
   108	}
   109	
   110	// STEP-0 instrumentation: when ONBOARDING_STEP_TRACE=1, emit one parseable line per
   111	// ACCEPTED advance so a single onboarding run reconstructs the current_step climb +
   112	// the data present at each step (see docs/step-0-canonical-step-table.md). Silent
   113	// (zero overhead) otherwise. Rejections already log via the handlers' reject lines.
   114	export function traceAdvanceStep0(
   115	  source: 'vapi' | 'direct',
   116	  args: {
   117	    currentStep: number;
   118	    targetStep: number;
   119	    data: Record<string, unknown>;
   120	    path: string | null;
   121	    brainDumpRaw: string | null;
   122	  },
   123	): void {
   124	  if (process.env.ONBOARDING_STEP_TRACE !== '1') return;
   125	  const { currentStep, targetStep, data, path, brainDumpRaw } = args;
   126	  const habits = data.habitConfigs as Record<string, unknown> | undefined;
   127	  const has = {
   128	    nickname: !!data.nickname,
   129	    path: !!path,
   130	    category: !!data.category,
   131	    goals: Array.isArray(data.goals) && data.goals.length > 0,
   132	    habitConfigs: !!habits && Object.keys(habits).length > 0,
   133	    morningCheckin: !!data.morningCheckin,
   134	    morningCheckinSkipped: data.morningCheckinSkipped === true,
   135	    reflectionConfig: !!data.reflectionConfig,
   136	    weeklyConfig: !!data.weeklyConfig,
   137	    brainDump: typeof brainDumpRaw === 'string' && brainDumpRaw.length > 0,
   138	  };
   139	  console.log(
   140	    `[step0] src=${source} current=${currentStep} target=${targetStep} has=${JSON.stringify(has)}`,
   141	  );
   142	}
   143	
   144	// Plan-review finalize precondition: habits (beginner or advanced) + reflection saved.
   145	export function checkPlanReady(data: Record<string, unknown>): {
   146	  hasHabits: boolean;
   147	  hasReflection: boolean;
   148	} {
   149	  const habitConfigs = data.habitConfigs as Record<string, unknown> | undefined;
   150	  const advancedHabitConfigs = data.advancedHabitConfigs as Record<string, unknown> | undefined;
   151	  const hasHabits =
   152	    (!!habitConfigs && Object.keys(habitConfigs).length > 0) ||
   153	    (!!advancedHabitConfigs && Object.keys(advancedHabitConfigs).length > 0);
   154	  return { hasHabits, hasReflection: !!data.reflectionConfig };
   155	}

