al:no-contrarian"]},{id:"gbreak-no-platitudes",rule:'No per-goal commentary or filler ("habit change is the foundation", "genuinely")',severity:"must",enforcedBy:["eval:no-platitudes"]},{id:"gbreak-silent-after-pick",rule:"Silent after each pick: no praise, no commentary, nothing except submit_goals and advance_step",severity:"must",enforcedBy:["eval:silent-after-pick"]},{id:"gbreak-one-line-wait",rule:"After the opener, asks one short pointer question then waits",severity:"must",enforcedBy:["eval:one-line-then-wait"]},{id:"gbreak-one-or-two",rule:"Allows one or two goals only; on three, asks which two matter most",severity:"must",enforcedBy:["eval:selection-cap"]}],rulesCode:[{id:"gbreak-tools-only",rule:"Only submit_goals and advance_step are callable on this beat",severity:"must",enforcedBy:["tool-contract-check"]},{id:"gbreak-canonical-values",rule:"submit_goals passes the exact canonical goal labels (never raw words or renamed labels) and includes the COMPLETE 1-2 selection",severity:"must",enforcedBy:["tool-contract-check"]},{id:"gbreak-advance-on-tool",rule:"advance_step fires only after submit_goals captured 1 to 2 valid goals",severity:"must",enforcedBy:["advance-gate-check"]},{id:"gbreak-goal-cap",rule:"At most two goals; floor of one goal to advance",severity:"must",enforcedBy:["advance-gate-check"]},{id:"gbreak-count-sets-branch",rule:"The goal count (1 or 2) is persisted so the downstream habits beat can distribute the 2-habit cap",severity:"must",enforcedBy:["advance-gate-check"]},{id:"gbreak-reveal-gates",rule:"The Goals tiles reveal gates on the opener clip end, never a fixed timer",severity:"must",enforcedBy:["reveal-timing-check"]},{id:"gbreak-audio-ownership",rule:"The opener resolves to a recorded clip; no live Cartesia (no {name} slot)",severity:"must",enforcedBy:["audio-ownership-check"]},{id:"gbreak-clip-resolves",rule:"onboard_beginner_02_break resolves to a real asset",severity:"must",enforcedBy:["render-link-integrity-check"]},{id:"gbreak-i