/bin/bash -lc "nl -ba ENFORCEMENT-AUDIT.md | sed -n '21,150p'; printf '\\n-- CI config --\\n'; find .github/workflows -type f -maxdepth 2 -print -exec sh -c 'nl -ba \""'$1" | sed -n "1,160p"'"' sh {} \\; 2>/dev/null; printf '\\n-- advance implementation --\\n'; find /home/ggvoice/gg-ground/gg-mvp/api/_lib/llm/onboarding -type f | grep -E 'advance|precondition|handler' | sed -n '1,100p'; nl -ba /home/ggvoice/gg-ground/gg-mvp/api/_lib/llm/onboarding/handlers/advanceStep.ts | sed -n '1,160p'; nl -ba /home/ggvoice/gg-ground/gg-mvp/api/_lib/llm/onboarding/preconditions.ts | sed -n '1,180p'" in /home/ggvoice/build/gg-render-bugs
