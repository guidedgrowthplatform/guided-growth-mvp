tic"]},{id:"havoidcrashes-no-read-list",rule:"Never reads the habit list aloud, in full or in part, not even one as an example",severity:"must",enforcedBy:["eval:no-read-options"]},{id:"havoidcrashes-no-sublists",rule:"Never reads sub-lists or anything the screen is not currently showing",severity:"must",enforcedBy:["eval:no-read-options"]},{id:"havoidcrashes-match-canonical",rule:"Matches the user's words to the closest canonical habit name; never invents a habit not on the list",severity:"must",enforcedBy:["eval:invalid-value-redirect"]},{id:"havoidcrashes-keep-the-gem",rule:"Keeps the less-is-more point: one kept habit beats five, small on purpose",severity:"must",enforcedBy:["eval:keep-the-gem"]},{id:"havoidcrashes-one-per-goal",rule:"With two goals, takes exactly one habit per goal; never two for a single goal",severity:"must",enforcedBy:["eval:single-select"]},{id:"havoidcrashes-silent-after-pick",rule:"Silent after each pick: no praise or commentary, nothing except add_habit, remove_habit and advance_step",severity:"must",enforcedBy:["eval:silent-after-pick"]},{id:"havoidcrashes-no-motivation",rule:"No commentary or motivation after each pick",severity:"must",enforcedBy:["eval:no-platitudes"]}],rulesCode:[{id:"havoidcrashes-tools-only",rule:"Only add_habit, remove_habit and advance_step are callable on this beat",severity:"must",enforcedBy:["tool-contract-check"]},{id:"havoidcrashes-canonical-values",rule:"add_habit passes the exact canonical habit name (never the raw words), or a custom name only when the user offers one not on the list",severity:"must",enforcedBy:["tool-contract-check"]},{id:"havoidcrashes-advance-on-tool",rule:"advance_step fires only after at least one habit is captured within the cap",severity:"must",enforcedBy:["advance-gate-check"]},{id:"havoidcrashes-habit-cap",rule:"At most two habits total; with two goals, one habit per goal; floor of one habit to advance",severity:"must",enforcedBy:["advance-gate-check"]},{id:"havoidcrashes-reveal-