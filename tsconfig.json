{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@gg/shared": ["packages/shared/src/index.ts"],
      "@gg/shared/*": ["packages/shared/src/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "packages/shared/src"]
}
