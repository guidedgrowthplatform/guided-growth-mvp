        "openerText": "Which of these feels most true for you?",
        "expectsInput": true,
        "directLlmAllowed": true
      },
      "tool": {
        "toolName": "submit_goals",
        "persistsFields": [
          "goals"
        ],
        "advancesStep": true
      },
      "persist": {
        "step": 4
      }
