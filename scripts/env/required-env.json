{
  "_comment": "Source of truth for env-var presence per Vercel scope. Checked by check-env.mjs. Production scope -> prod Supabase; Preview scope -> staging Supabase.",
  "scopes": {
    "production": {
      "required": [
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "DATABASE_URL",
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_ANON_KEY",
        "OPENAI_API_KEY"
      ]
    },
    "preview": {
      "required": [
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "DATABASE_URL",
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_ANON_KEY",
        "VITE_PUBLIC_WEB_ORIGIN",
        "VITE_IS_QA_SURFACE"
      ]
    }
  },
  "forbiddenInProduction": [
    "VITE_IS_QA_SURFACE",
    "QA_LOGIN_ENABLED",
    "QA_UNIVERSAL_PASSWORD",
    "QA_RESET_TOKEN_ENABLED",
    "QA_SELF_RESET_ENABLED",
    "STAGING_SEED_ENABLED"
  ]
}
