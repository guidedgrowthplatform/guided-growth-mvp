{
  "name": "life-growth-tracker",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev --listen 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "cap:local": "VITE_API_URL=http://$(ipconfig getifaddr en0):3000 npm run build && npx cap sync ios",
    "cap:sync": "npx cap sync ios && node scripts/patch-ios-plist.mjs",
    "cap:sync:android": "npx cap sync android",
    "cap:sync:all": "npx cap sync ios && node scripts/patch-ios-plist.mjs && npx cap sync android",
    "cap:open": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@huggingface/transformers": "^3.8.1",
    "@iconify/react": "^6.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@sentry/react": "^10.47.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@types/mixpanel-browser": "^2.60.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.577.0",
    "mixpanel-browser": "^2.77.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.20.0",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/sanitize-html": "^2.16.1",
    "@vercel/node": "^5.6.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.84.5",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9"
  }
}
