{
  "name": "life-growth-tracker",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "ulimit -n 524288 && set -a && . ./.env.local && set +a && vercel dev --listen 3000",
    "predev:api": "npm run build:shared",
    "icons:bundle": "node scripts/build-icon-bundle.mjs",
    "build:shared": "tsc -b packages/shared",
    "postinstall": "tsc -b packages/shared",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "knip": "knip",
    "knip:report": "knip --reporter compact > knip-report.txt || true",
    "prepare": "husky",
    "cap:local": "VITE_API_URL=http://$(ipconfig getifaddr en0):3000 npm run build && npx cap sync ios && node scripts/patch-ios-disable-firebase.mjs",
    "cap:live": "CAP_LIVE_RELOAD_URL=http://localhost:5173 npx cap sync ios && node scripts/patch-ios-disable-firebase.mjs && xattr -cr ios/App && CAP_LIVE_RELOAD_URL=http://localhost:5173 npx cap run ios",
    "cap:sync": "npx cap sync ios && node scripts/patch-ios-plist.mjs && node scripts/patch-ios-push.mjs && node scripts/patch-ios-disable-firebase.mjs",
    "cap:sync:android": "npx cap sync android && node scripts/patch-android-manifest.mjs",
    "cap:sync:all": "npx cap sync ios && node scripts/patch-ios-plist.mjs && node scripts/patch-ios-push.mjs && node scripts/patch-ios-disable-firebase.mjs && npx cap sync android && node scripts/patch-android-manifest.mjs",
    "cap:open": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "db:push": "npx supabase db push",
    "vapi:sync": "tsx --env-file=.env.local scripts/vapi-sync/sync.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "~8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "~8.1.0",
    "@capacitor/core": "~8.1.0",
    "@capacitor/ios": "~8.1.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@cartesia/cartesia-js": "^3.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@sentry/node": "^10.57.0",
    "@sentry/react": "^10.48.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@vapi-ai/web": "2.5.2",
    "@vercel/functions": "^3.7.1",
    "date-fns": "^2.30.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.577.0",
    "openai": "^6.39.0",
    "pg": "^8.11.3",
    "posthog-js": "^1.369.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.20.0",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.4",
    "@iconify/json": "2.2.478",
    "@iconify/utils": "3.1.3",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/sanitize-html": "^2.16.1",
    "@vercel/node": "^5.6.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.14.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.32.6",
    "supabase": "^2.84.5",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9"
  }
}
