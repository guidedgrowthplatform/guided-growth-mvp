# Supabase (data layer)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side — required for API routes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_USE_SUPABASE=true

# Better Auth
# VITE_BETTER_AUTH_URL is baked into the client at build time.
# For Capacitor mobile builds, this MUST be the production HTTPS URL
# (e.g. https://guided-growth-mvp-six.vercel.app) so the WebView can
# reach the API server. For local web dev, use http://localhost:5173.
VITE_BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres
# Set to 'true' in production to use __Secure- cookie prefix.
# Leave unset or 'false' when Capacitor mobile clients need auth.
BETTER_AUTH_SECURE_COOKIES=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/callback/google

# Voice APIs
OPENAI_API_KEY=sk-your-openai-key
ELEVENLABS_API_KEY=sk_your-elevenlabs-key

# GitLab Project Status Dashboard
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_PROJECT_ID=79765225

# Analytics & Error Tracking
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=

# Auth bypass — ONLY for local dev without auth setup. NEVER in production.
AUTH_BYPASS_MODE=false
