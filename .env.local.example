# ─── Supabase (client-side) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public web origin used as the auth email redirect target. Required for
# native builds (window.location.origin inside the WebView is not a real URL).
# Web dev: leave unset to use window.location.origin.
VITE_PUBLIC_WEB_ORIGIN=https://guided-growth-mvp.vercel.app


# ─── Supabase (server-side — required for API routes) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres

# ─── Voice / AI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# Coach LLM provider flag. 'openai' (default, or unset) = zero behavior change.
# 'azure' = route the coach loop (api/_lib/llm/openai-responses.ts) through
# Azure OpenAI instead of direct OpenAI. Reversible at request time, no
# redeploy needed to flip back. See api/_lib/llm/openai.ts for the getters.
LLM_PROVIDER=openai

# Only needed when LLM_PROVIDER=azure. Endpoint is the resource host (no
# trailing path); the client builds {endpoint}/openai/v1/... internally — the
# unified Responses API surface (the classic /openai/deployments/{d}/...
# path 404s for Responses). api-version 'preview' is the validated value.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=preview
# Deployment names on the Azure resource, mapped from the app's two logical
# model tiers ('gpt-4o' onboarding, 'gpt-4o-mini' everything else) — see
# resolveModel() in openai-responses.ts.
AZURE_OPENAI_DEPLOYMENT_ONBOARDING=your-onboarding-tier-deployment-name
AZURE_OPENAI_DEPLOYMENT_DEFAULT=your-default-tier-deployment-name

# Cartesia REST (Sonic TTS) — Path 2 check-ins and async voice
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_VOICE_ID=your-cartesia-voice-id

# Soniox (STT) — server-to-server bearer key for /api/stt
SONIOX_API_KEY=your-soniox-api-key

# Vapi (Path 1 onboarding — Coach Yair)
# Public key: Vapi dashboard → API Keys → Public Key
# Assistant ID: Vapi dashboard → Assistants → Coach Yair → copy ID
VITE_VAPI_PUBLIC_KEY=your-vapi-public-key
VITE_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Enable Path 3 State 3 (voice-in streaming via Soniox realtime). Default off.
VITE_STATE3_ENABLED=false

# Vapi (server-side — required for tool sync + webhook). NO VITE_ prefix.
# Private key:    Vapi dashboard → API Keys → Private Key
# Webhook secret: generate locally with `openssl rand -hex 32`; same value
#                 must be in Vercel env AND set on every tool via sync script
# Base URL:       Where Vapi POSTs tool calls. Use the prod Vercel domain.
VAPI_PRIVATE_KEY=your-vapi-private-key
VAPI_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
VAPI_WEBHOOK_BASE_URL=https://guided-growth-mvp.vercel.app

# ─── Google Sheets API (Voice Sync Script) ───────────────────────────────────
GOOGLE_SHEET_ID=your-google-sheet-id

# ─── Analytics & Error Tracking ──────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── QA quick-login (dev/QA builds only) ─────────────────────────────────────
# Shared password for the qa-onboarding-* test accounts. Required for the QA
# screen's one-tap sign-in; must match QA_PASSWORD passed to scripts/qa/create-test-users.mjs.
VITE_QA_PASSWORD=

# ─── GitLab Project Status Dashboard ────────────────────────────────────────
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_PROJECT_ID=79765225

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@mail.guidedgrowthapp.com
FEEDBACK_ALERT_TO=tech@guidedgrowthapp.com

# ─── Dev Only ────────────────────────────────────────────────────────────────
# Auth bypass — ONLY for local dev without auth setup. NEVER in production.
AUTH_BYPASS_MODE=false

# Override the API base URL when running `npm run dev` against a non-default
# Vercel function port (default 3000). Not needed in production — Vercel
# resolves /api on the same origin as the SPA bundle.

# ─── Per-environment native identity (dev / staging / main) ──────────────────
# Used by capacitor.config.ts + fastlane to build a distinct app per stage.
# Leave unset for the default production single-env build. In CI these come
# from the GitHub Environment's Variables, not from this file.
# See docs/ENVIRONMENTS.md.
#   APP_IDENTIFIER      bundle id / package name, e.g. app.guidedgrowth.dev
#   APP_DISPLAY_NAME    home-screen name, e.g. "GG Dev"
#   CAP_EXTRA_NAV_HOSTS extra allowNavigation hosts (this stage's Supabase host),
#                       comma-separated
#   MATCH_GIT_BRANCH    (optional) fastlane match repo branch, defaults to main
APP_IDENTIFIER=app.guidedgrowth.mvp
APP_DISPLAY_NAME=Guided Growth Tracker
CAP_EXTRA_NAV_HOSTS=
# VITE_API_URL=http://localhost:3000
