# ─── Supabase (client-side) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (server-side — required for API routes) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres

# ─── Voice / AI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_VOICE_MALE=your-cartesia-voice-id
CARTESIA_MODEL=sonic-3

# ─── Voice tuning (optional overrides for src/lib/config/voice.ts) ──────────
# VITE_VOICE_MAX_CONVERSATIONS=5
# VITE_VOICE_TTS_MS_PER_CHAR=65
# VITE_VOICE_TTS_MIN_MS=2000
# VITE_STT_SHORT_COMMAND_THRESHOLD_SECONDS=5
# VITE_STT_DOWNSAMPLE_RATE=16000
# VITE_AUDIO_DEBUG_WEB_ORIGIN=https://guided-growth-mvp-green.vercel.app

# ─── Google Sheets API (Voice Sync Script) ───────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEET_ID=your-google-sheet-id

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Analytics & Error Tracking ──────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=

# ─── GitLab Project Status Dashboard ────────────────────────────────────────
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_PROJECT_ID=79765225

# ─── Dev Only ────────────────────────────────────────────────────────────────
# Auth bypass — ONLY for local dev without auth setup. NEVER in production.
AUTH_BYPASS_MODE=false
