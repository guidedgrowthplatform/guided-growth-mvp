# ─── Supabase (client-side) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key


# ─── Supabase (server-side — required for API routes) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres

# ─── Voice / AI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_VOICE_ID=your-cartesia-voice-id

# Cartesia Line Agent — set after running `cartesia deploy` from
# the gg-voice-mvp agent repo. Required by useRealtimeVoice hook.
VITE_CARTESIA_AGENT_ID=your-agent-id

# ─── Cartesia Line Agent (LLM tuning) ────────────────────────────────────────
# Used by `scripts/cartesia-line-agent/main.py` and `scripts/cartesia-line-agent/agent.py`
# when running locally or on Cartesia’s hosted agent platform.
CARTESIA_LINE_LLM_MODEL=openai/gpt-4o-mini
CARTESIA_LINE_LLM_TEMPERATURE=0.7
CARTESIA_LINE_LLM_MAX_TOKENS=250
CARTESIA_LINE_INTRODUCTION=Hey — what's on your mind today?
# CARTESIA_LINE_SYSTEM_PROMPT=...
# CARTESIA_LINE_SYSTEM_PROMPT_FILE=./system-prompt.txt

# ─── Google Sheets API (Voice Sync Script) ───────────────────────────────────
GOOGLE_SHEET_ID=your-google-sheet-id

# ─── Analytics & Error Tracking ──────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── GitLab Project Status Dashboard ────────────────────────────────────────
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_PROJECT_ID=79765225

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@mail.yourdomain.com

# ─── Dev Only ────────────────────────────────────────────────────────────────
# Auth bypass — ONLY for local dev without auth setup. NEVER in production.
AUTH_BYPASS_MODE=false

# Override the API base URL when running `npm run dev` against a non-default
# Vercel function port (default 3000). Not needed in production — Vercel
# resolves /api on the same origin as the SPA bundle.
# VITE_API_URL=http://localhost:3000
