# ─── Supabase (client-side) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (server-side — required for API routes) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres

# ─── Voice / AI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_VOICE_MALE=your-cartesia-voice-id
CARTESIA_MODEL=sonic-3

# Cartesia Line Agent — set after running `cartesia deploy` from
# scripts/cartesia-line-agent/. Required by useRealtimeVoice hook.
VITE_CARTESIA_AGENT_ID=your-agent-id

# ─── Google Sheets API (Voice Sync Script) ───────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEET_ID=your-google-sheet-id

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Analytics & Error Tracking ──────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── GitLab Project Status Dashboard ────────────────────────────────────────
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_PROJECT_ID=79765225

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@mail.yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# ─── Reflections (AI Insight) ────────────────────────────────────────────────
# Vercel AI Gateway key for Claude Haiku reflection insights (dev fallback;
# on Vercel, OIDC auth is used automatically when this is not set)
AI_GATEWAY_API_KEY=
# Feature flag — set to "true" to enable AI insight generation
AI_INSIGHTS_ENABLED=false

# ─── Dev Only ────────────────────────────────────────────────────────────────
# Auth bypass — ONLY for local dev without auth setup. NEVER in production.
AUTH_BYPASS_MODE=false
