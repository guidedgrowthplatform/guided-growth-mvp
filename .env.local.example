# ─── Supabase (client-side) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (server-side — required for API routes) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres

# ─── Voice / AI ──────────────────────────────────────────────────────────────
# OpenAI is used for transcript analysis + command parsing (not STT/TTS)
OPENAI_API_KEY=sk-your-openai-key

# Cartesia is the MVP STT/TTS provider (Sonic-3 + Ink)
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_VOICE_MALE=your-cartesia-voice-id
CARTESIA_MODEL=sonic-3
CARTESIA_STT_MODEL=ink-whisper
CARTESIA_STT_LANGUAGE=en
# STT provider switch (MVP uses Cartesia; Deepgram returns in Phase 3)
STT_PROVIDER=cartesia
# TTS provider switch (MVP uses Cartesia; ElevenLabs returns in Phase 3)
TTS_PROVIDER=cartesia

# ─── Google Sheets API (Voice Sync Script) ───────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEET_ID=your-google-sheet-id

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Analytics & Error Tracking ──────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=

# ─── GitLab Project Status Dashboard ────────────────────────────────────────
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_PROJECT_ID=79765225

# ─── Dev Only ────────────────────────────────────────────────────────────────
# Auth bypass — ONLY for local dev without auth setup. NEVER in production.
AUTH_BYPASS_MODE=false
